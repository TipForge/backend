{
  "name": "tipforge-backend",
  "version": "0.1.0",
  "description": "TipForge backend - Payment orchestration and Stellar integration",
  "type": "module",
  "main": "dist/index.js",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "fastify": "^4.27.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "@fastify/cors": "^9.0.1",
    "pino": "^8.17.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "eslint": "^9.3.0",
    "prettier": "^3.3.3",
    "tsx": "^4.17.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
