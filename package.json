{
  "name": "tipforge-backend",
  "version": "0.1.0",
  "description": "TipForge backend - Payment orchestration and Stellar integration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0",
    "@stellar/stellar-sdk": "^12.0.0",
    "bullmq": "^5.17.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "fastify-cors": "^9.0.1",
    "fastify-jwt": "^7.2.4",
    "redis": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "eslint": "^9.3.0",
    "prettier": "^3.3.3",
    "prisma": "^5.17.0",
    "tsx": "^4.17.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
